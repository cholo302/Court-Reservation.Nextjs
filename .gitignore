# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# environment variables (NEVER commit .env with secrets)
.env
.env.local
.env*.local
.env.production

# Allow example/template env files
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database (SQLite)
*.sqlite
*.sqlite-journal
prisma/*.sqlite
prisma/*.sqlite-journal

# uploaded user content (generated at runtime)
public/uploads/proofs/*
public/uploads/users/*
public/uploads/qrcodes/*
!public/uploads/qrcodes/gcash-qr.jpg
!public/uploads/proofs/.gitkeep
!public/uploads/users/.gitkeep
!public/uploads/qrcodes/.gitkeep

# platform-specific SWC binaries (auto-installed by npm)
@next/swc-*