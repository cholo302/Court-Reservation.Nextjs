# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# environment variables (NEVER commit .env with secrets)
.env
.env.local
.env*.local
.env.production

# Local build artifacts from rollbacks (Windows permission issues with bracket chars)
src/app/api/courts/[courtId]/
src/app/api/courts/photos/

# Allow example/template env files
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database journal files
*.sqlite-journal
prisma/*.sqlite-journal

# platform-specific SWC binaries (auto-installed by npm)
@next/swc-*