# ==============================================================
# Court Reservation - PRODUCTION Environment Variables
# ==============================================================
# On your Ubuntu VPS, copy this to .env and fill in real values:
#   cp .env.production.example .env
#
# Generate NEXTAUTH_SECRET with:
#   openssl rand -base64 32
# ==============================================================

# Database (SQLite)
DATABASE_URL="file:./court_reservation.sqlite"

# NextAuth (REQUIRED - app will crash without these)
NEXTAUTH_URL="http://YOUR_SERVER_IP_OR_DOMAIN:3000"
NEXTAUTH_SECRET="REPLACE_WITH_OUTPUT_OF: openssl rand -base64 32"

# App Settings
APP_NAME="Court Reservation"
BOOKING_ADVANCE_DAYS=14
RESERVATION_EXPIRY_MINUTES=30
OPERATING_START_HOUR=6
OPERATING_END_HOUR=22
PEAK_HOURS_START=17
PEAK_HOURS_END=21

# Payment Settings
NEXT_PUBLIC_GCASH_PHONE="09123456789"

# Google reCAPTCHA v2 (get keys from https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-site-key-here"
RECAPTCHA_SECRET_KEY="your-secret-key-here"

# Social Login (Optional - leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
