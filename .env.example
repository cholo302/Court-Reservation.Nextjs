# ==============================================================
# Court Reservation - Environment Variables
# ==============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env          (Mac/Linux)
#   copy .env.example .env        (Windows)
# ==============================================================

# Database (SQLite - no extra setup needed)
DATABASE_URL="file:./court_reservation.sqlite"

# NextAuth (REQUIRED)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-string"
# Generate a secret: npx auth secret  OR  openssl rand -base64 32

# App Settings (Optional - defaults shown)
APP_NAME="Court Reservation"
BOOKING_ADVANCE_DAYS=14
RESERVATION_EXPIRY_MINUTES=30
OPERATING_START_HOUR=6
OPERATING_END_HOUR=22
PEAK_HOURS_START=17
PEAK_HOURS_END=21

# Payment Settings
NEXT_PUBLIC_GCASH_PHONE="09123456789"

# Social Login (Optional - leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
